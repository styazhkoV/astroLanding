---
const projects = [
  {
    title: "Реставрация Ванн",
    description: "Коммерческий лендинг с высокой конверсией для бизнеса по восстановлению эмали ванн. Оптимизирован для мобильных устройств.",
    image: "/projects/restvanna.png",
    link: "https://styazhkov.github.io/alexsnow-restvanna.github.io/"
  },
  {
    title: "Личный Портфолио",
    description: "Минималистичный и стильный сайт-визитка для демонстрации творческих работ и контактов.",
    image: "/projects/portfolio.png",
    link: "https://styazhkov.github.io/"
  }
];
---

<section id="portfolio" class="py-24 px-4 bg-dark-bg/50">
  <div class="container mx-auto">
    <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-8">
      <div class="max-w-2xl">
        <h2 class="text-4xl md:text-5xl font-black mb-4">Наши <span class="text-neon-cyan">работы</span></h2>
        <p class="text-white/60">Реальные примеры того, как мы помогаем бизнесу выйти на новый уровень производительности и дизайна.</p>
      </div>
      <div class="hidden md:block">
        <div class="h-[2px] w-32 bg-gradient-to-r from-neon-cyan to-transparent"></div>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
      {projects.map(project => (
        <div class="group relative overflow-hidden rounded-3xl glass hover:border-neon-cyan/50 transition-all duration-500">
          <div class="aspect-video overflow-hidden">
            <img 
              src={project.image} 
              alt={project.title} 
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            />
          </div>
          <div class="p-8">
            <h3 class="text-2xl font-bold mb-3 group-hover:text-neon-cyan transition-colors">{project.title}</h3>
            <p class="text-white/60 mb-6 line-clamp-2">{project.description}</p>
            <a 
              href={project.link} 
              target="_blank" 
              class="inline-block px-6 py-3 rounded-xl border border-white/10 hover:border-neon-cyan hover:bg-neon-cyan/10 transition-all duration-300 font-semibold"
            >
              Смотреть проект
            </a>
          </div>
          
          <!-- Decorative glow -->
          <div class="absolute -bottom-8 -right-8 w-32 h-32 bg-neon-cyan/10 blur-3xl rounded-full opacity-0 group-hover:opacity-100 transition-opacity"></div>
        </div>
      ))}
    </div>
  </div>
</section>
